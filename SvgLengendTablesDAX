Dynamic Lengend PBI Svg = 
VAR _Value =
    SELECTEDVALUE('Table'[LengendField])

VAR _Color =
    SWITCH(
        _Value,
        "A",            "%HEXCode", - change # into %23 
        "B",            "%HEXCode",
        "C",            "%HEXCode",
                        "%HEXCode"
    )

VAR _SVG =
    "<svg xmlns='http://www.w3.org/2000/svg' width='16' height='16'>"
    & "<circle cx='8' cy='8' r='6' fill='" & _Color & "'/>"
    & "</svg>"


RETURN
    "data:image/svg+xml;utf8," & _SVG
